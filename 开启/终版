## 阶段2：核心系统完整代码实现
### 步骤2.1 创建核心系统代码文件
在`/home/ulm_mar_v2/code`目录下创建`ulm_mar_main.py`，将以下完整代码复制进去，代码已完全适配A100 80G显卡，无冗余兼容内容：
```python
import faiss
import numpy as np
import lz4.frame
import psutil
import time
import torch
import logging
from typing import List, Dict, Optional, Tuple
from pydantic import BaseModel
from sentence_transformers import SentenceTransformer
from collections import OrderedDict
from threading import Lock
from transformers import (
    AutoModelForCausalLM,
    AutoTokenizer,
    BitsAndBytesConfig
)

# ====================== 日志配置 ======================
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s",
    handlers=[
        logging.FileHandler("/home/ulm_mar_v2/logs/system.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

# ====================== 一、A100 80G专属核心配置 ======================
# 4bit量化配置（A100满血bf16精度）
BNB_CONFIG = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_use_double_quant=True,
    bnb_4bit_quant_type="nf4",
    bnb_4bit_compute_dtype=torch.bfloat16
)
# 全局固定配置
VECTOR_DIM = 384
MAX_SHORT_MEM = 200
MAX_HOT_MEM = 1000
SHORT_MEM_MAX_SIZE = 512 * 1024 * 1024  # 512MB，A100扩容
HOT_MEM_MAX_SIZE = 1024 * 1024 * 1024   # 1GB，A100扩容
ENABLE_COMPRESSION = True
VECTOR_QUANTIZE_TYPE = "INT8"
GLOBAL_DEVICE = "cuda:0"  # A100单卡统一设备

# ====================== 二、核心数据结构定义 ======================
class MemoryItem(BaseModel):
    """记忆条目结构化定义"""
    memory_id: str
    content: str
    compressed_content: Optional[bytes] = None
    vector: np.ndarray
    memory_type: str  # short_term/long_term/experience
    task_type: Optional[str] = None
    agent_role: str = "global"
    access_count: int = 0
    create_time: float
    last_access_time: float
    is_compressed: bool = False
    importance_score: float = 0.0  # 经验重要性权重

class AgentInfo(BaseModel):
    """智能体注册信息"""
    agent_id: str
    agent_name: str
    model_name_or_path: str
    capability_tags: List[str]  # 能力标签
    base_accuracy: Dict[str, float]  # 各任务基线准确率
    memory_quota: int = 128  # 内存配额，单位MB
    is_strong_agent: bool = False
    device: str = GLOBAL_DEVICE

class KnowledgeTriple(BaseModel):
    """结构化知识三元组"""
    head: str
    relation: str
    tail: str

# ====================== 三、双模态统一底层语义记忆核心模块（ULSM） ======================
class UnifiedLowLevelSemanticMemory:
    def __init__(self):
        self.vector_dim = VECTOR_DIM
        self.enable_compression = ENABLE_COMPRESSION
        self.quantize_type = VECTOR_QUANTIZE_TYPE
        
        # 向量编码模型，CPU运行不占A100显存
        self.encoder = SentenceTransformer('all-MiniLM-L6-v2', device="cpu")
        logger.info("向量编码模型加载完成")
        
        # 结构化知识图谱
        self.kg_graph: List[KnowledgeTriple] = []
        self.protected_memory_ids: set = set()
        
        # 四级分层记忆
        self.super_short_mem = OrderedDict()
        self.max_super_short = 32
        
        self.short_term_mem = OrderedDict()
        self.max_short_mem = MAX_SHORT_MEM
        self.short_mem_max_size = SHORT_MEM_MAX_SIZE
        self.short_mem_lock = Lock()
        
        self.hot_long_term_mem = OrderedDict()
        self.max_hot_mem = MAX_HOT_MEM
        self.hot_mem_max_size = HOT_MEM_MAX_SIZE
        self.hot_mem_lock = Lock()
        
        # A100专属GPU-FAISS索引
        self.cold_long_term_mem: List[MemoryItem] = []
        self._init_gpu_faiss_index()
        
        # 统计指标
        self.total_memory_usage = 0
        self.memory_fragmentation = 0.0
        logger.info("双模态统一记忆库初始化完成")

    def _init_gpu_faiss_index(self):
        """A100专属GPU-FAISS索引初始化，检索延迟降低90%"""
        res = faiss.StandardGpuResources()
        if self.quantize_type == "INT8":
            cpu_index = faiss.IndexScalarQuantizer(self.vector_dim, faiss.ScalarQuantizer.QT_8bit)
            self.index = faiss.index_cpu_to_gpu(res, 0, cpu_index)
        elif self.quantize_type == "INT4":
            cpu_index = faiss.IndexScalarQuantizer(self.vector_dim, faiss.ScalarQuantizer.QT_4bit)
            self.index = faiss.index_cpu_to_gpu(res, 0, cpu_index)
        else:
            cpu_index = faiss.IndexFlatL2(self.vector_dim)
            self.index = faiss.index_cpu_to_gpu(res, 0, cpu_index)
        self.id_to_memory: Dict[int, MemoryItem] = {}
        self.next_id = 0
        logger.info("A100 GPU-FAISS索引初始化完成")

    def _encode_text(self, text: str) -> np.ndarray:
        """文本转向量，CPU运行无显存占用"""
        vec = self.encoder.encode([text], normalize_embeddings=True)[0].astype(np.float32)
        return vec

    def _compress_content(self, content: str) -> bytes:
        """LZ4无损压缩"""
        if not self.enable_compression:
            return content.encode("utf-8")
        return lz4.frame.compress(content.encode("utf-8"))

    def _decompress_content(self, compressed_data: bytes) -> str:
        """LZ4解压缩"""
        if not self.enable_compression:
            return compressed_data.decode("utf-8")
        return lz4.frame.decompress(compressed_data).decode("utf-8")

    def _calc_memory_size(self, item: MemoryItem) -> int:
        """计算单条记忆内存占用"""
        size = 0
        if item.is_compressed:
            size += len(item.compressed_content)
        else:
            size += len(item.content.encode("utf-8"))
        size += item.vector.nbytes
        return size

    def _lru_evict_with_protection(self, mem_dict: OrderedDict, max_size: int, current_size: int) -> int:
        """带核心经验保护的LRU淘汰，解决灾难性遗忘"""
        while current_size > max_size and mem_dict:
            mem_id, old_item = mem_dict.popitem(last=False)
            if mem_id in self.protected_memory_ids:
                mem_dict[mem_id] = old_item
                mem_dict.move_to_end(mem_id, last=False)
                continue
            current_size -= self._calc_memory_size(old_item)
        return current_size

    def add_knowledge_triple(self, triple: KnowledgeTriple):
        """添加结构化知识三元组"""
        self.kg_graph.append(triple)

    def add_memory(
        self,
        content: str,
        memory_type: str = "short_term",
        task_type: Optional[str] = None,
        agent_role: str = "global",
        is_experience: bool = False,
        knowledge_triples: Optional[List[KnowledgeTriple]] = None
    ) -> str:
        """写入记忆核心入口"""
        vec = self._encode_text(content)
        memory_id = f"mem_{int(time.time() * 1000)}_{self.next_id}"
        current_time = time.time()

        # 压缩处理
        is_compressed = self.enable_compression and memory_type != "short_term"
        compressed_content = self._compress_content(content) if is_compressed else None

        # 计算重要性权重
        importance_score = 0.7 if is_experience else 0.3
        if knowledge_triples:
            importance_score += 0.2
            for triple in knowledge_triples:
                self.add_knowledge_triple(triple)

        # 构建记忆条目
        item = MemoryItem(
            memory_id=memory_id,
            content=content if not is_compressed else "",
            compressed_content=compressed_content,
            vector=vec,
            memory_type=memory_type,
            task_type=task_type,
            agent_role=agent_role,
            access_count=0,
            create_time=current_time,
            last_access_time=current_time,
            is_compressed=is_compressed,
            importance_score=importance_score
        )

        item_size = self._calc_memory_size(item)

        # 核心经验保护
        if importance_score >= 0.8:
            self.protected_memory_ids.add(memory_id)

        # 分层写入
        if memory_type == "short_term":
            with self.short_mem_lock:
                self.short_term_mem[memory_id] = item
                self.short_term_mem.move_to_end(memory_id)
                self.total_memory_usage += item_size
                self.total_memory_usage = self._lru_evict_with_protection(
                    self.short_term_mem, self.short_mem_max_size, self.total_memory_usage
                )
        elif is_experience or memory_type == "long_term":
            with self.hot_mem_lock:
                self.hot_long_term_mem[memory_id] = item
                self.hot_long_term_mem.move_to_end(memory_id)
                self.total_memory_usage += item_size
                if len(self.hot_long_term_mem) > self.max_hot_mem:
                    cold_id, cold_item = self.hot_long_term_mem.popitem(last=False)
                    self._write_to_cold_index(cold_item)
                    self.total_memory_usage -= self._calc_memory_size(cold_item)
        else:
            self.super_short_mem[memory_id] = item
            if len(self.super_short_mem) > self.max_super_short:
                self.super_short_mem.popitem(last=False)

        logger.debug(f"记忆写入成功，ID：{memory_id}，类型：{memory_type}")
        return memory_id

    def _write_to_cold_index(self, item: MemoryItem):
        """写入冷数据GPU-FAISS索引"""
        self.index.add(np.expand_dims(item.vector, axis=0))
        self.id_to_memory[self.next_id] = item
        self.next_id += 1
        self.cold_long_term_mem.append(item)

    def search_memory(
        self,
        query: str,
        top_k: int = 5,
        memory_type: Optional[str] = None,
        task_type: Optional[str] = None,
        agent_capability: Optional[List[str]] = None
    ) -> Tuple[List[MemoryItem], List[KnowledgeTriple]]:
        """双模态检索核心入口"""
        query_vec = self._encode_text(query)
        results: List[MemoryItem] = []

        # 优先检索热记忆
        with self.short_mem_lock:
            for item in self.short_term_mem.values():
                if memory_type and item.memory_type != memory_type:
                    continue
                if task_type and item.task_type != task_type:
                    continue
                results.append(item)

        with self.hot_mem_lock:
            for item in self.hot_long_term_mem.values():
                if memory_type and item.memory_type != memory_type:
                    continue
                if task_type and item.task_type != task_type:
                    continue
                results.append(item)

        # 检索冷记忆
        if len(results) < top_k:
            D, I = self.index.search(np.expand_dims(query_vec, axis=0), top_k - len(results))
            for idx in I[0]:
                if idx in self.id_to_memory:
                    item = self.id_to_memory[idx]
                    if item.is_compressed:
                        item.content = self._decompress_content(item.compressed_content)
                    with self.hot_mem_lock:
                        if item.memory_id not in self.hot_long_term_mem:
                            self.hot_long_term_mem[item.memory_id] = item
                            self.hot_long_term_mem.move_to_end(item.memory_id)
                    results.append(item)

        # 相似度排序
        results.sort(key=lambda x: np.dot(x.vector, query_vec), reverse=True)
        top_results = results[:top_k]

        # 结构化知识召回
        related_triples = []
        for triple in self.kg_graph:
            if query in triple.head or query in triple.tail:
                related_triples.append(triple)

        # 弱智能体适配
        if agent_capability and "weak" in agent_capability:
            for item in top_results:
                if item.is_compressed and not item.content:
                    item.content = self._decompress_content(item.compressed_content)

        # 更新访问统计
        for item in top_results:
            item.access_count += 1
            item.last_access_time = time.time()
            item.importance_score = min(1.0, item.importance_score + 0.05 * item.access_count)
            if item.importance_score >= 0.8:
                self.protected_memory_ids.add(item.memory_id)

        return top_results, related_triples

    def distill_structured_experience(self, reasoning_trace: str, task_type: str, agent_id: str, is_strong_agent: bool):
        """强智能体推理轨迹结构化蒸馏"""
        if not is_strong_agent:
            return
        # 拆解推理轨迹为三元组
        reasoning_steps = [step.strip() for step in reasoning_trace.split("\n") if step.strip()]
        knowledge_triples = []
        for step in reasoning_steps:
            if "因为" in step and "所以" in step:
                head = step.split("因为")[-1].split("所以")[0].strip()
                tail = step.split("所以")[-1].strip()
                triple = KnowledgeTriple(head=head, relation="逻辑推导", tail=tail)
                knowledge_triples.append(triple)
            elif "->" in step or "=>" in step:
                parts = step.split("->" if "->" in step else "=>")
                if len(parts) >= 2:
                    triple = KnowledgeTriple(head=parts[0].strip(), relation="步骤推导", tail=parts[1].strip())
                    knowledge_triples.append(triple)
        
        # 双模态写入记忆
        experience_content = f"""
        【任务类型】{task_type}
        【推理逻辑三元组】{[t.dict() for t in knowledge_triples]}
        【完整推理轨迹】{reasoning_trace}
        【错误规避方案】推理过程中的易错点与校验方法
        """
        self.add_memory(
            content=experience_content,
            memory_type="long_term",
            task_type=task_type,
            agent_role=agent_id,
            is_experience=True,
            knowledge_triples=knowledge_triples
        )
        logger.info(f"强智能体经验蒸馏完成，任务类型：{task_type}，三元组数量：{len(knowledge_triples)}")

    def get_memory_stats(self) -> Dict:
        """获取系统统计指标"""
        process = psutil.Process()
        gpu_used = torch.cuda.memory_used(GLOBAL_DEVICE) / 1024 / 1024
        gpu_total = torch.cuda.get_device_properties(GLOBAL_DEVICE).total_memory / 1024 / 1024
        return {
            "total_memory_usage_mb": self.total_memory_usage / 1024 / 1024,
            "process_rss_mb": process.memory_info().rss / 1024 / 1024,
            "gpu_used_mb": gpu_used,
            "gpu_total_mb": gpu_total,
            "gpu_usage_rate": gpu_used / gpu_total,
            "short_mem_count": len(self.short_term_mem),
            "hot_mem_count": len(self.hot_long_term_mem),
            "cold_mem_count": len(self.cold_long_term_mem),
            "kg_triple_count": len(self.kg_graph),
            "protected_memory_count": len(self.protected_memory_ids),
            "memory_fragmentation": self.memory_fragmentation
        }

# ====================== 四、记忆管控中间件 ======================
class MemoryControlMiddleware:
    def __init__(self, ulsm: UnifiedLowLevelSemanticMemory):
        self.ulsm = ulsm
        self.agent_memory_quota: Dict[str, int] = {}
        self.read_write_lock = Lock()
        logger.info("记忆管控中间件初始化完成")

    def register_agent_quota(self, agent_info: AgentInfo):
        """注册智能体内存配额"""
        self.agent_memory_quota[agent_info.agent_id] = agent_info.memory_quota * 1024 * 1024
        logger.info(f"智能体 {agent_info.agent_id} 内存配额注册完成，配额：{agent_info.memory_quota}MB")

    def agent_read_memory(
        self,
        agent_info: AgentInfo,
        query: str,
        top_k: int = 5,
        task_type: Optional[str] = None
    ) -> Tuple[List[MemoryItem], List[KnowledgeTriple]]:
        """智能体读记忆接口"""
        agent_cap = ["weak"] if not agent_info.is_strong_agent else ["strong"]
        with self.read_write_lock:
            return self.ulsm.search_memory(
                query=query,
                top_k=top_k,
                task_type=task_type,
                agent_capability=agent_cap
            )

    def agent_write_memory(
        self,
        agent_info: AgentInfo,
        content: str,
        memory_type: str = "short_term",
        task_type: Optional[str] = None,
        is_experience: bool = False,
        knowledge_triples: Optional[List[KnowledgeTriple]] = None
    ):
        """智能体写记忆接口"""
        with self.read_write_lock:
            return self.ulsm.add_memory(
                content=content,
                memory_type=memory_type,
                task_type=task_type,
                agent_role=agent_info.agent_id,
                is_experience=is_experience,
                knowledge_triples=knowledge_triples
            )

    def agent_distill_experience(self, agent_info: AgentInfo, trace: str, task_type: str):
        """智能体经验蒸馏接口"""
        with self.read_write_lock:
            self.ulsm.distill_structured_experience(trace, task_type, agent_info.agent_id, agent_info.is_strong_agent)

# ====================== 五、多智能体调度与推理分布对齐层 ======================
class AgentScheduler:
    def __init__(self, middleware: MemoryControlMiddleware):
        self.middleware = middleware
        self.agent_registry: Dict[str, AgentInfo] = {}
        self.agent_model_cache: Dict[str, Tuple[AutoModelForCausalLM, AutoTokenizer]] = {}
        self.strong_agent_id: Optional[str] = None
        logger.info("多智能体调度器初始化完成")

    def register_agent(self, agent_info: AgentInfo):
        """注册智能体，自动加载模型"""
        self.agent_registry[agent_info.agent_id] = agent_info
        self.middleware.register_agent_quota(agent_info)
        
        # 加载模型到A100
        logger.info(f"正在加载智能体 {agent_info.agent_name} 到 {agent_info.device}...")
        tokenizer = AutoTokenizer.from_pretrained(agent_info.model_name_or_path, trust_remote_code=True)
        tokenizer.pad_token = tokenizer.eos_token
        model = AutoModelForCausalLM.from_pretrained(
            agent_info.model_name_or_path,
            quantization_config=BNB_CONFIG,
            device_map=agent_info.device,
            trust_remote_code=True
        )
        # A100专属推理加速
        model = torch.compile(model)
        self.agent_model_cache[agent_info.agent_id] = (model, tokenizer)
        
        if agent_info.is_strong_agent:
            self.strong_agent_id = agent_info.agent_id
        logger.info(f"智能体 {agent_info.agent_name} 加载完成！")

    def _build_aligned_prompt(self, agent_info: AgentInfo, task: str, task_type: str) -> str:
        """构建能力对齐prompt"""
        memory_items, knowledge_triples = self.middleware.agent_read_memory(
            agent_info=agent_info,
            query=task,
            top_k=3,
            task_type=task_type
        )
        memory_context = "\n".join([f"【全局参考经验】{item.content}" for item in memory_items])
        kg_context = "\n".join([f"【推理逻辑】{t.head} {t.relation} {t.tail}" for t in knowledge_triples])
        full_context = f"{memory_context}\n{kg_context}"
        
        if not agent_info.is_strong_agent:
            base_prompt = f"""<|system|>
你是{agent_info.agent_name}，必须严格基于下方的全局统一参考信息完成推理，不得偏离。
全局统一参考信息是所有智能体共享的唯一可信内容，包含强基准智能体的成熟推理框架，你必须完全遵循该框架完成推理，保证结果与全局基准一致。
{full_context}
<|user|>
当前任务：{task}
请输出你的完整推理过程与最终结论，每一步都必须有全局参考信息支撑。
<|assistant|>
"""
        else:
            base_prompt = f"""<|system|>
你是强基准智能体{agent_info.agent_name}，需要完成高质量推理，输出完整、可复用的推理框架与解题步骤，保证事实准确、逻辑严谨。
{full_context}
<|user|>
当前任务：{task}
请输出完整的推理轨迹与最终结论。
<|assistant|>
"""
        return base_prompt

    def _agent_inference_with_mira(self, agent_info: AgentInfo, prompt: str, task_type: str, max_new_tokens: int = 1024) -> Tuple[str, str]:
        """MIRA推理时记忆引导的分布对齐核心方法"""
        model, tokenizer = self.agent_model_cache[agent_info.agent_id]
        # 召回强智能体经验软标签
        memory_items, _ = self.middleware.agent_read_memory(
            agent_info=agent_info,
            query=prompt,
            top_k=2,
            task_type=task_type
        )
        soft_attention_labels = []
        for item in memory_items:
            if "推理逻辑三元组" in item.content:
                step_tokens = tokenizer.encode(item.content, return_tensors="pt").to(agent_info.device)
                soft_attention_labels.append(step_tokens)
        
        inputs = tokenizer(prompt, return_tensors="pt").to(agent_info.device)
        with torch.no_grad():
            # 注意力对齐钩子
            def attention_hook(module, input, output):
                attn_output, attn_weights = output
                if soft_attention_labels and not agent_info.is_strong_agent:
                    align_weight = 0.3 if agent_info.base_accuracy.get("general", 0.6) > 0.6 else 0.5
                    for label in soft_attention_labels:
                        if label.shape[-1] <= attn_weights.shape[-1]:
                            attn_weights[:, :, :label.shape[-1], :label.shape[-1]] = (1-align_weight) * attn_weights[:, :, :label.shape[-1], :label.shape[-1]] + align_weight * label
                return (attn_output, attn_weights)
            
            # 注册钩子
            hooks = []
            for layer in model.model.layers:
                hooks.append(layer.self_attn.register_forward_hook(attention_hook))
            
            # 推理
            outputs = model.generate(
                **inputs,
                max_new_tokens=max_new_tokens,
                temperature=0.3,
                top_p=0.8,
                do_sample=True,
                pad_token_id=tokenizer.eos_token_id
            )
            
            # 移除钩子
            for hook in hooks:
                hook.remove()
        
        # 解析输出
        full_text = tokenizer.decode(outputs[0], skip_special_tokens=True)
        response = full_text[len(tokenizer.decode(inputs.input_ids[0], skip_special_tokens=True)):].strip()
        if "最终结论" in response:
            trace, conclusion = response.split("最终结论", 1)
            trace = trace.strip()
            conclusion = "最终结论" + conclusion
        else:
            trace = response
            conclusion = response[-200:]
        return trace, conclusion

    def joint_reasoning(self, task: str, task_type: str = "general") -> Dict:
        """多智能体联合推理主入口"""
        logger.info(f"开始联合推理，任务类型：{task_type}，任务：{task[:50]}...")
        # 1. 任务初始化
        self.middleware.agent_write_memory(
            agent_info=next(iter(self.agent_registry.values())),
            content=f"全局任务：{task}，任务类型：{task_type}",
            memory_type="short_term",
            task_type=task_type
        )

        # 2. 强智能体基准推理
        strong_trace = ""
        strong_conclusion = ""
        if self.strong_agent_id:
            strong_agent = self.agent_registry[self.strong_agent_id]
            strong_prompt = self._build_aligned_prompt(strong_agent, task, task_type)
            strong_trace, strong_conclusion = self._agent_inference_with_mira(strong_agent, strong_prompt, task_type)
            self.middleware.agent_distill_experience(strong_agent, strong_trace, task_type)
            self.middleware.agent_write_memory(
                agent_info=strong_agent,
                content=f"强智能体基准结论：{strong_conclusion}，推理轨迹：{strong_trace}",
                memory_type="short_term",
                task_type=task_type
            )
            logger.info(f"强智能体基准推理完成，结论：{strong_conclusion[:100]}...")

        # 3. 弱智能体对齐推理
        agent_results = {}
        for agent_id, agent_info in self.agent_registry.items():
            if agent_info.is_strong_agent:
                agent_results[agent_id] = {
                    "reasoning_trace": strong_trace,
                    "conclusion": strong_conclusion,
                    "is_strong_agent": True
                }
                continue
            agent_prompt = self._build_aligned_prompt(agent_info, task, task_type)
            trace, conclusion = self._agent_inference_with_mira(agent_info, agent_prompt, task_type)
            self.middleware.agent_write_memory(
                agent_info=agent_info,
                content=f"{agent_info.agent_name}推理结果：{conclusion}，轨迹：{trace}",
                memory_type="short_term",
                task_type=task_type
            )
            agent_results[agent_id] = {
                "reasoning_trace": trace,
                "conclusion": conclusion,
                "is_strong_agent": False
            }
            logger.info(f"弱智能体 {agent_info.agent_name} 推理完成")

        # 4. 结果融合与指标计算
        all_conclusions = [res["conclusion"] for res in agent_results.values()]
        consistency_rate = len(set(all_conclusions)) / len(all_conclusions)
        final_conclusion = strong_conclusion if self.strong_agent_id else max(set(all_conclusions), key=all_conclusions.count)

        result = {
            "task": task,
            "task_type": task_type,
            "final_conclusion": final_conclusion,
            "agent_results": agent_results,
            "metrics": {
                "result_consistency_rate": consistency_rate,
                "agent_count": len(self.agent_registry),
                "memory_stats": self.middleware.ulsm.get_memory_stats()
            }
        }
        logger.info(f"联合推理完成，结果一致性率：{consistency_rate*100}%")
        return result

# ====================== 六、系统入口与快速测试 ======================
